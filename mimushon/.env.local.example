# ── Database connection (required) ────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

DB_USER=your_db_user
DB_HOST=your_db_host
DB_NAME=your_db_name
DB_PASSWORD=your_db_password
DB_PORT=5432

# ── Site origin (used for CSRF origin validation) ─────────────────────────────
# Must match the exact origin your frontend is served from (no trailing slash).
# Defaults to "https://mimushon.co.il" when not set.
NEXT_PUBLIC_SITE_ORIGIN=https://mimushon.co.il

# ── Analytics (optional — defaults are hardcoded fallbacks if not set) ─────────
# Prefer setting these here so they can be rotated without a code deploy.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_search_console_token

# ── Node environment ───────────────────────────────────────────────────────────
# Set to "production" in your hosting environment to enable HSTS + SSL on the DB pool.
NODE_ENV=development
